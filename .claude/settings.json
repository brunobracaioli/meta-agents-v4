{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "autoDreamEnable": true,
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(env)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(tree:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(which:*)",

      "Bash(git init)",
      "Bash(git remote add:*)",
      "Bash(git push:*)",
      "Edit(./.gitignore)",

      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",

      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(git status)",
      "Bash(gh:*)",

      "Glob",
      "Grep",
      "Read(./**)",
      "Edit(./src/**)",
      "Edit(./tests/**)",
      "Edit(./docs/**)",
      "Edit(./migrations/**)",
      "Edit(./infra/**)",
      "Write(./src/**)",
      "Write(./tests/**)",
      "Write(./docs/**)",
      "Write(./migrations/**)",
      "Write(./infra/**)",

      "mcp__meta-ads-mcp__ads_get_ad_accounts",
      "mcp__meta-ads-mcp__ads_get_ad_entities",
      "mcp__meta-ads-mcp__ads_get_dataset_details",
      "mcp__meta-ads-mcp__ads_get_dataset_quality",
      "mcp__meta-ads-mcp__ads_get_dataset_stats",
      "mcp__meta-ads-mcp__ads_get_errors",
      "mcp__meta-ads-mcp__ads_get_help_article",
      "mcp__meta-ads-mcp__ads_get_opportunity_score",
      "mcp__meta-ads-mcp__ads_get_pages_for_business",
      "mcp__meta-ads-mcp__ads_insights_advertiser_context",
      "mcp__meta-ads-mcp__ads_insights_anomaly_signal",
      "mcp__meta-ads-mcp__ads_insights_auction_ranking_benchmarks",
      "mcp__meta-ads-mcp__ads_insights_industry_benchmark",
      "mcp__meta-ads-mcp__ads_insights_performance_trend",
      "mcp__meta-ads-mcp__ads_catalog_get_catalogs",
      "mcp__meta-ads-mcp__ads_catalog_get_details",
      "mcp__meta-ads-mcp__ads_catalog_get_diagnostics",
      "mcp__meta-ads-mcp__ads_catalog_get_feed_rules",
      "mcp__meta-ads-mcp__ads_catalog_get_product_details",
      "mcp__meta-ads-mcp__ads_catalog_get_product_feed_details",
      "mcp__meta-ads-mcp__ads_catalog_get_product_set_products",
      "mcp__meta-ads-mcp__ads_catalog_get_product_sets",
      "mcp__meta-ads-mcp__ads_catalog_get_products",
      "mcp__meta-ads-mcp__ads_create_campaign",
      "mcp__meta-ads-mcp__ads_create_ad_set",
      "mcp__meta-ads-mcp__ads_create_ad",
      "mcp__meta-ads-mcp__ads_catalog_create",
      "mcp__meta-ads-mcp__ads_activate_entity",
      "mcp__meta-ads-mcp__ads_update_entity"
    ],

    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|mcp__meta-ads-mcp__ads_create_campaign|mcp__supabase__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/remind-update-project-memory.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task|Agent|Skill|WebFetch|WebSearch|mcp__meta-ads-mcp__ads_.*|mcp__supabase__execute_sql|mcp__supabase__apply_migration",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/emit-agent-event.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/emit-agent-event.py\""
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "cleanupPeriodDays": 30
}

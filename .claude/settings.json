{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "autoDreamEnable": true,
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(env)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(test:*)",
      "Bash(tree:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(which:*)",

      "Bash(git init)",
      "Bash(git remote add:*)",
      "Bash(git push:*)",
      "Edit(./.gitignore)",

      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",

      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git stash:*)",
      "Bash(git status)",
      "Bash(gh:*)",

      "Glob",
      "Grep",
      "Read(./**)",

      "WebFetch",
      "WebSearch",

      "Edit(./src/**)",
      "Edit(./tests/**)",
      "Edit(./docs/**)",
      "Edit(./migrations/**)",
      "Edit(./infra/**)",
      "Write(./src/**)",
      "Write(./tests/**)",
      "Write(./docs/**)",
      "Write(./migrations/**)",
      "Write(./infra/**)",

      "mcp__meta-ads-mcp__ads_get_ad_accounts",
      "mcp__meta-ads-mcp__ads_get_ad_entities",
      "mcp__meta-ads-mcp__ads_get_dataset_details",
      "mcp__meta-ads-mcp__ads_get_dataset_quality",
      "mcp__meta-ads-mcp__ads_get_dataset_stats",
      "mcp__meta-ads-mcp__ads_get_errors",
      "mcp__meta-ads-mcp__ads_get_help_article",
      "mcp__meta-ads-mcp__ads_get_opportunity_score",
      "mcp__meta-ads-mcp__ads_get_pages_for_business",
      "mcp__meta-ads-mcp__ads_insights_advertiser_context",
      "mcp__meta-ads-mcp__ads_insights_anomaly_signal",
      "mcp__meta-ads-mcp__ads_insights_auction_ranking_benchmarks",
      "mcp__meta-ads-mcp__ads_insights_industry_benchmark",
      "mcp__meta-ads-mcp__ads_insights_performance_trend",
      "mcp__meta-ads-mcp__ads_catalog_get_catalogs",
      "mcp__meta-ads-mcp__ads_catalog_get_details",
      "mcp__meta-ads-mcp__ads_catalog_get_diagnostics",
      "mcp__meta-ads-mcp__ads_catalog_get_feed_rules",
      "mcp__meta-ads-mcp__ads_catalog_get_product_details",
      "mcp__meta-ads-mcp__ads_catalog_get_product_feed_details",
      "mcp__meta-ads-mcp__ads_catalog_get_product_set_products",
      "mcp__meta-ads-mcp__ads_catalog_get_product_sets",
      "mcp__meta-ads-mcp__ads_catalog_get_products",
      "mcp__meta-ads-mcp__ads_create_campaign",
      "mcp__meta-ads-mcp__ads_create_ad_set",
      "mcp__meta-ads-mcp__ads_create_ad",
      "mcp__meta-ads-mcp__ads_catalog_create",
      "mcp__meta-ads-mcp__ads_activate_entity",
      "mcp__meta-ads-mcp__ads_update_entity",

      "mcp__claude_ai_MCP_META_ADS_B2_TECH__meta_token_status",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__list_ad_accounts",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__list_campaigns",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__list_adsets",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__list_ads",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__list_creatives",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__get_insights",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__run_insights_report",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__create_campaign",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__create_adset",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__create_creative",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__create_ad",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__update_campaign",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__update_adset",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__update_ad",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__pause_campaign",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__pause_adset",
      "mcp__claude_ai_MCP_META_ADS_B2_TECH__pause_ad",

      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__google_token_status",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__list_accessible_customers",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__list_campaigns",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__list_ad_groups",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__list_ads",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__get_insights",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__run_insights_report",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__generate_keyword_ideas",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__create_search_campaign",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__create_campaign_budget",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__create_campaign",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__create_ad_group",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__create_responsive_search_ad",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__add_keywords",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__add_negative_keywords",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__create_sitelinks",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__create_callouts",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__create_structured_snippet",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__add_geo_targeting",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__add_age_targeting",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__get_search_terms",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__get_recommendations",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__list_conversion_actions",
      "mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__get_conversion_tags"
    ],

    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|mcp__.+__ads_create_campaign|mcp__.+__create_campaign|mcp__.+__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/remind-update-project-memory.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/enforce-research-allowlist.py\""
          }
        ]
      },
      {
        "matcher": "Task|Agent|Skill|WebFetch|WebSearch|mcp__.+__ads_.+|mcp__.+__(create|update|pause|copy)_(campaign|adset|ad|creative)|mcp__.+__get_insights|mcp__.+__run_insights_report|mcp__.+__list_(campaigns|adsets|ads|creatives)|mcp__.+__execute_sql|mcp__.+__apply_migration|mcp__claude_ai_MCP_GOOGLE_ADS_B2_TECH__.+",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/emit-agent-event.py\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/emit-agent-event.py\""
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "cleanupPeriodDays": 30
}

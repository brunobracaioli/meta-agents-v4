# meta-agents-v4 — secrets do runner Fly.io
#
# Este arquivo é referência. Os valores reais vivem em:
#   - .env (local dev, gitignored)
#   - `fly secrets` (produção)
#
# Para sincronizar prod:
#   while IFS='=' read -r k v; do
#     [[ -z "$k" || "$k" =~ ^# ]] && continue
#     fly secrets set "$k=$v"
#   done < .env.local

# ---------- Claude / Anthropic ----------
# Fallback para SDK quando OAuth do CLI não cobrir (ex.: skills que chamam Anthropic API direto).
CLAUDE_API_KEY=sk-ant-...

# ---------- OpenAI (image-generate) ----------
OPENAI_API_KEY=sk-...

# ---------- Supabase ----------
SUPABASE_URL=https://<project-ref>.supabase.co
# Server-side, bypassa RLS. Substitui a legacy SUPABASE_SERVICE_ROLE_KEY (JWT).
SUPABASE_SECRET_KEY=sb_secret_...
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
# Client-side. Substitui a legacy SUPABASE_ANON_KEY (JWT).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# ---------- Upstash Redis (cache + idempotência) ----------
UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXX...

# ---------- Upstash QStash (queue / scheduler dinâmico) ----------
QSTASH_TOKEN=eyJ...
QSTASH_CURRENT_SIGNING_KEY=sig_...
QSTASH_NEXT_SIGNING_KEY=sig_...

# ---------- Budget caps (HARD limits respeitados pelas skills) ----------
WORKSPACE_MAX_DAILY_BUDGET_CENTS=5000
WORKFLOW_LLM_BUDGET_USD_CAP=2.00

# ---------- Cloudflare Pages (skill create-landing-page-*) ----------
# Deploy de landing pages estáticas sob <nome>.b2tech.io (ADR 0012). Token com escopo
# Pages (Zone DNS Edit é opcional — o bind mesma-conta auto-cria o CNAME). NUNCA commitar.
# Em prod (runner Fly) vai por `fly secrets set`.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ---------- Telegram (notificação das análises) ----------
# chat_id de destino do resumo da skill analytic-traffic-brunobracaioli-campaign.
# Opcional: se ausente, a skill degrada para log-only (não falha). Em prod vai por `fly secrets`.
TELEGRAM_CHAT_ID=

# ---------- Resend (email do modo autônomo do Ultron — ADR 0019 Fase 3) ----------
# API key do Resend (https://resend.com). Usada por scripts/send-email.cjs no Passo N da skill
# autonomous-watch-tick p/ avisar o operador que a landing page ficou no ar. Opcional: sem ela o
# modo autônomo degrada (narra + encerra, sem email). Em prod vai por `fly secrets`. NUNCA commitar.
# O REMETENTE exige domínio verificado no Resend (b2tech.io).
RESEND_API_KEY=re_...
# Overrides opcionais (default: bruno@b2tech.io / "Ultron <ultron@b2tech.io>").
AUTONOMOUS_NOTIFY_EMAIL=bruno@b2tech.io
AUTONOMOUS_FROM_EMAIL=Ultron <ultron@b2tech.io>

# ---------- Web dashboard (Vercel / web/) ----------
# Gate de acesso do operador: hash SHA-256 (hex) da senha do dashboard.
#   echo -n "minha-senha" | sha256sum
DASHBOARD_PASSWORD=<sha256-hex-da-senha>
# Segredo para assinar o cookie JWT de sessão (>= 32 bytes aleatórios).
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=<random-hex>
# Estratégia de auth. "password" = senha única legada (login só com senha).
# "supabase" = auth por operador (login com EMAIL+senha, carimba operator_id nos jobs).
# PRODUÇÃO roda "supabase" (pós-cutover Fase 7). Dev DEVE espelhar isso — se ausente, o
# default vira "password" e os agent_jobs nascem com operator_id=null (runner não claima).
# Paridade dev/prod: docs/how-to/local-development.md
AUTH_MODE=supabase
# ElevenLabs (TTS do Ultron).
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=<voice-id>
# Picovoice Porcupine (wake word "Ultron", free tier) — https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=
# Exposto ao browser (build): chave pública usada no client do wake word.
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=


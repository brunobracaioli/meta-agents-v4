# Never bake these into the image — go via fly secrets instead
.env
.env.*

# VCS and IDE
.git/
.gitignore
.vscode/
.idea/

# Local tooling
node_modules/
venv/
__pycache__/
*.pyc

# Build artifacts and logs
*.log
*.bak
*.tmp
/var/log/runs/

# Local outputs (not needed in the image; volume + Supabase carry state)
tentativas-geracao-de-campanhas/
.claude/materiais-das-empresas/*/generated-ads/
.claude/materiais-das-empresas/*/imagens-geradas/

# Landing-page build artifacts (rebuilt at run; _template deps pre-baked in image)
landing-pages/**/out/
landing-pages/**/.next/
landing-pages/**/.gen/
# Never bake generated per-LP clones (incl. fixtures like cca-e2e) into the runner image —
# the skills scaffold them at run time from _template. Only _template ships in the image.
landing-pages/*
!landing-pages/_template

# Plan / scratch artifacts
docs/spec-driven/

# Self
Dockerfile
.dockerignore
fly.toml
